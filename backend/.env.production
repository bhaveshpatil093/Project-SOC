# All values MUST be set — no defaults assumed
ES_HOST=                    # REQUIRED
ES_PASSWORD=                # REQUIRED — use secrets manager
DEBUG=false
LOG_LEVEL=INFO
SLM_LOAD_IN_4BIT=true       # Use 4-bit if GPU available
JWT_SECRET_KEY=             # REQUIRED — generate with: openssl rand -hex 32
CORS_ORIGINS=["https://soc.istrac.isro.gov.in"]
