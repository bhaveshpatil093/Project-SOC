# Elasticsearch (REQUIRED)
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=elastic
ES_PASSWORD=your_password_here    # REQUIRED — no default
ES_VERIFY_CERTS=false
ES_TIMEOUT=30
ES_MAX_RETRIES=3

# Application Web Server
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Pipeline & Machine Learning Limits
WINDOW_MINUTES=5
THREAT_SCORE_THRESHOLD=0.3
INGESTION_INTERVAL_MINUTES=5
MAX_LOGS_PER_FETCH=1000

# Model Serialization Paths
MODEL_DIR=backend/models/saved
RETRAIN_DAY=sun
RETRAIN_HOUR=2

# SLM Model & Cache
SLM_MODEL_NAME=auto              # "auto" uses fine-tuned if available
SLM_MAX_NEW_TOKENS=512
SLM_TEMPERATURE=0.3
SLM_LOAD_IN_4BIT=false           # Set true if you have GPU + bitsandbytes
SLM_CACHE_TTL_SECONDS=3600
SLM_CACHE_SEMANTIC_THRESHOLD=0.92

# RAG Database
CHROMA_PERSIST_DIR=./data/chroma_db
RAG_N_RESULTS=5
RAG_AUTO_REINDEX_THRESHOLD=10

# Conversation Memory Maps
MAX_CONVERSATIONS=100
CONVERSATION_TTL_HOURS=24

# MLFlow Tracking Config
MLFLOW_TRACKING_URI=sqlite:///./data/mlflow.db
MLFLOW_EXPERIMENT_NAME=soc-anomaly-detection
