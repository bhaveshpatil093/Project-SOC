# Environment Settings
# Set SOC_ENVIRONMENT to one of: development, staging, production, test

# Elasticsearch Configuration
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=elastic
ES_PASSWORD=                        # REQUIRED: Elastic user password
ES_VERIFY_CERTS=false               # Set to true in production

# App Configuration
DEBUG=true                          # Set to false in production
LOG_LEVEL=DEBUG                     # INFO in production
APP_PORT=8000
JWT_SECRET_KEY=                     # REQUIRED: Use `openssl rand -hex 32` for production
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Pipeline & Scoring
THREAT_SCORE_THRESHOLD=0.3
WINDOW_MINUTES=5

# Small Language Model (SLM) Settings
SLM_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0 # auto or hf-id or path
SLM_LOAD_IN_4BIT=false              # Set to true if running on GPU

# Paths
MODEL_DIR=backend/models/saved
CHROMA_PERSIST_DIR=./data/chroma_db
MLFLOW_TRACKING_URI=sqlite:///./data/mlflow.db
